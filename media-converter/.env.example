# .env.local

# OpenRouter API Key - Để sử dụng tính năng phân tích kịch bản AI
# Lấy từ: https://openrouter.ai/
VITE_OPENROUTER_API_KEY=sk_live_your_api_key_here

# Google Cloud TTS API Key - Để chuyển text sang giọng nói chất lượng cao
# Lấy từ: https://cloud.google.com/text-to-speech
VITE_GOOGLE_TTS_KEY=your_google_tts_key_here

# Stability AI API - Để tạo hình ảnh từ mô tả văn bản (tuỳ chọn)
# VITE_STABILITY_AI_KEY=your_stability_ai_key_here